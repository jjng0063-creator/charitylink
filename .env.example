# Firebase client configuration.
VITE_FIREBASE_API_KEY="YOUR_FIREBASE_API_KEY"
VITE_FIREBASE_AUTH_DOMAIN="YOUR_PROJECT.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="YOUR_FIREBASE_PROJECT_ID"
VITE_FIREBASE_STORAGE_BUCKET="YOUR_PROJECT.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="YOUR_MESSAGING_SENDER_ID"
VITE_FIREBASE_APP_ID="YOUR_FIREBASE_APP_ID"
VITE_FIREBASE_DATABASE_URL="https://YOUR_PROJECT-default-rtdb.firebaseio.com"
VITE_FIREBASE_FIRESTORE_DATABASE_ID="(optional)"

# APP_URL: The URL where this applet is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Server-side Gemini key for /api/categorize middleware endpoint.
GEMINI_API_KEY="YOUR_SERVER_GEMINI_API_KEY"

# Optional endpoint protections.
# CATEGORIZE_MAX_BODY_BYTES="900000"
# CATEGORIZE_RATE_WINDOW_MS="600000"
# CATEGORIZE_RATE_MAX="30"
